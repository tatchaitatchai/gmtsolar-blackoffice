# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามจริง
#   cp .env.example .env

# สตริงเชื่อมต่อ Postgres (ตรงกับ docker-compose.dev.yml)
DATABASE_URL=postgres://gmt:gmt_dev_password@localhost:5432/gmt_solar

# กุญแจลับสำหรับเซ็น JWT — production ให้สุ่มค่ายาว ๆ
JWT_SECRET=dev-secret-change-me-in-production

# พอร์ตที่ API เปิดให้บริการ (8080 มักถูก Docker อื่นใช้ จึงใช้ 8088)
PORT=8088

# ระดับ log
RUST_LOG=info,gmt_solar_api=debug
