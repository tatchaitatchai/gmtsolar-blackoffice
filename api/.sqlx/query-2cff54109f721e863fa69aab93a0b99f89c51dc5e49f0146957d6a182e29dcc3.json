  "db_name": "PostgreSQL",
  "query": "SELECT pi.id, pi.product_id, p.name AS product_name, p.model AS product_model,\n                  p.use_unit, pi.quantity\n           FROM package_items pi\n           JOIN products p ON p.id = pi.product_id\n           WHERE pi.package_id = $1\n           ORDER BY p.name",
